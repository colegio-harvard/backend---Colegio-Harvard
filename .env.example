# ============================================================
# BACKEND — VARIABLES DE ENTORNO
# ============================================================
# Copiar este archivo como ".env" y completar los valores.
# El archivo .env NO se sube al repositorio (está en .gitignore).
# ============================================================

# ===================== DESARROLLO LOCAL =====================
# Usar estos valores para trabajar en tu máquina con PostgreSQL local.
# La base de datos local es "db_colegio_fernando".

NODE_ENV=development
PORT=4000

# Base de datos LOCAL
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=tu_password_local
DB_NAME=db_colegio_fernando
DB_PORT=5432
DATABASE_URL="postgresql://postgres:tu_password_local@localhost:5432/db_colegio_fernando?schema=public"

JWT_SECRET=tu_secreto_jwt_aqui

# Timezone del proceso Node (SIEMPRE UTC — la zona civil se maneja en código)
TZ=UTC

# CORS — en local no hace falta configurar (permite todo por defecto)
# CORS_ORIGIN=*

# ===================== WASABI (Object Storage) ================
# Almacenamiento de archivos (fotos de alumnos, adjuntos de mensajes).
# Mismas credenciales para desarrollo y producción (bucket compartido).
WASABI_ACCESS_KEY=tu_access_key_wasabi
WASABI_SECRET_KEY=tu_secret_key_wasabi
WASABI_BUCKET=colegio-fernando-storage
WASABI_BUCKET_BACKUPS=colegio-fernando-backups
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# ===================== RAILWAY (producción) =================
# En Railway estas variables se configuran desde el DASHBOARD,
# NO en un archivo .env. Se documentan aquí solo como referencia.
#
# NODE_ENV=production
# PORT=<inyectado automáticamente por Railway>
# DATABASE_URL=<inyectado por el plugin PostgreSQL de Railway>
# DB_HOST=<host de Railway>
# DB_USER=<usuario de Railway>
# DB_PASSWORD=<password de Railway>
# DB_NAME=<nombre de la DB en Railway>
# DB_PORT=<puerto de Railway>
# JWT_SECRET=<secreto seguro para producción>
# TZ=UTC
# CORS_ORIGIN=https://tu-frontend.up.railway.app
